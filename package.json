{
  "name": "discord_bot",
  "description": "Discord Bot using discord.js",
  "license": "MIT",
  "scripts": {
    "bot": "node --env-file=.env dist/bot.js",
    "bot:local": "node --watch --env-file=.env dist/bot.js",
    "build": "node esbuild.config.mjs",
    "build:local": "node esbuild.config.mjs",
    "format": "npx prettier . --write --ignore-unknown",
    "format:check": "npx prettier . --check --ignore-unknown",
    "lint": "npx eslint ./src"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "dependencies": {
    "discord.js": "^14.16.3"
  }
}
